# ==============================================================================
# MIL-STD-498 HTTPS PROXY CONFIGURATION FILE
# ==============================================================================
# SYSTEM:             Rootcastle Home Watcher Stack
# SUBSYSTEM:          HTTPS Ingress Proxy Subsystem (Caddy)
# FILE NAME:          Caddyfile
# VERSION:            1.2.0
# DATE:               2026-06-15
# SECURITY CLASSIF:   UNCLASSIFIED
# DESCRIPTION:        Configures the reverse proxy path from port 10443 to the
#                     loopback Frigate NVR port 8971, enforcing TLS 1.3.
# ==============================================================================
{
	auto_https disable_redirects
}

:10443 {
	tls /etc/caddy/certs/frigate-local.crt /etc/caddy/certs/frigate-local.key
	encode zstd gzip

	reverse_proxy https://127.0.0.1:8971 {
		transport http {
			tls_insecure_skip_verify
		}
		header_up Host {host}
		header_up X-Forwarded-Proto https
	}
}
