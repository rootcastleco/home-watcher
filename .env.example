# ==============================================================================
# MIL-STD-498 ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# SYSTEM:             Rootcastle Home Watcher Stack
# FILE NAME:          .env.example
# VERSION:            1.2.0
# DATE:               2026-06-15
# SECURITY CLASSIF:   UNCLASSIFIED
# DESCRIPTION:        Template for environment variables defining system
#                     parameters, camera feeds, credentials, and tokens.
# ==============================================================================

# Core System Settings
TZ=Europe/Istanbul
FRIGATE_RTSP_PASSWORD=change-me
FRIGATE_SHM_SIZE=256mb

# Camera & Device IP Configurations
FRIGATE_DVR_IP=10.0.10.10
FRIGATE_PTZ_IP=10.0.10.20
FRIGATE_ESP32_IP=10.0.10.30
FRIGATE_PRINTER_IP=10.0.10.40

# Camera Credentials
FRIGATE_DVR_USER=admin
FRIGATE_DVR_PASSWORD=change-me
FRIGATE_PTZ_USER=admin
FRIGATE_PTZ_PASSWORD=change-me
FRIGATE_ESP32_USER=rootcastle
FRIGATE_ESP32_PASSWORD=change-me

# Alert Service Integration Keys (DO NOT COMMIT REAL VALUES)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=https://localhost:10443

# Camera polling and notification policy.
ALERT_CAMERAS=ofis,giris_1,giris_2,ptz_dis,esp32_ofis
ALERT_OFFICE_CAMERAS=ofis,esp32_ofis
ALERT_POLL_INTERVAL_SECONDS=3
ALERT_COOLDOWN_SECONDS=90
ALERT_OFFICE_COOLDOWN_SECONDS=60
ALERT_MOTION_PIXEL_RATIO=0.035
ALERT_RATE_LIMIT_BACKOFF_SECONDS=600
ALERT_HTTP_TIMEOUT_SECONDS=12

# Configurable alerts, external links, and interactive command polling
ALERT_LABELS=person,cat,bird,dog
FRIGATE_EXTERNAL_URL=https://localhost:10443
TELEGRAM_POLLING_ENABLED=true

# FLSun T1 3D Printer camera and motion monitoring settings
PRINTER_ENABLED=true
PRINTER_SNAPSHOT_URL=http://localhost/webcam/?action=snapshot
PRINTER_CHECK_INTERVAL_SECONDS=20
PRINTER_MOVEMENT_THRESHOLD_PCT=0.5

